{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@vrweb/sdk": ["src/vrweb.d.ts"]
    },
    "strict": true,
    "noEmit": true,
    "skipLibCheck": false,
    "lib": ["ES2022"]
  },
  "include": [
    "fixtures/**/*.ts",
    "generated/**/*.d.ts",
    "src/**/*.d.ts"
  ]
}
