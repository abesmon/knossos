            "type": "shell",
            "command": "${workspaceFolder}/build.sh all",
            "group": { "kind": "build", "isDefault": true },
            "presentation": { "reveal": "always", "panel": "dedicated", "clear": true },
            "problemMatcher": []
        },
        {
            "label": "Build: macOS",
            "type": "shell",
            "command": "${workspaceFolder}/build.sh mac",
            "group": "build",
            "presentation": { "reveal": "always", "panel": "dedicated", "clear": true },
            "problemMatcher": []
        },
        {
            "label": "Build: Windows",
            "type": "shell",
            "command": "${workspaceFolder}/build.sh win",
            "group": "build",
            "presentation": { "reveal": "always", "panel": "dedicated", "clear": true },
            "problemMatcher": []
        },
        {
            "label": "Build: Linux",
            "type": "shell",
            "command": "${workspaceFolder}/build.sh linux",
            "group": "build",
            "presentation": { "reveal": "always", "panel": "dedicated", "clear": true },
            "problemMatcher": []
        },
        {
            "label": "Build: Clean",
            "type": "shell",
            "command": "${workspaceFolder}/build.sh --clean",
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared", "clear": true },
            "problemMatcher": []
