<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Голосовой чат: доступ к микрофону. Под hardened runtime обязателен,
	     при ad-hoc без него тоже работает (хватает NSMicrophoneUsageDescription),
	     но держим для готовности к нотаризации. См. docs/voice-chat.md. -->
	<key>com.apple.security.device.audio-input</key>
	<true/>
</dict>
</plist>
