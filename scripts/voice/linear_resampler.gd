class_name LinearResampler
extends RefCounted

## Потоковый линейный ресемплер моно-семплов с произвольным соотношением частот.
## Состояние (фаза + последний семпл прошлого буфера) переносится между вызовами process(),
## поэтому на стыках буферов нет щелчков — это важно, т.к. захват микрофона приходит
## кусками переменной длины каждый кадр.
##
## Линейная интерполяция — простейший приличный вариант: дешёвый и без звона. Для голоса
## @ 24 кГц её хватает; качественный полифазный ресемплинг — задача на потом (вместе с Opus).

var _src_rate: float
var _dst_rate: float
var _step: float   # сколько семплов источника на один семпл назначения
var _pos := 0.0    # дробная позиция чтения в текущем входном буфере (может быть < 0 — в _prev)
var _prev := 0.0   # последний семпл предыдущего буфера (виртуальный индекс -1)
var _primed := false


func _init(src_rate: float, dst_rate: float) -> void:
	_src_rate = src_rate
	_dst_rate = dst_rate
	_step = src_rate / dst_rate


## Ресемплит входной моно-буфер, дописывая результат в out (чтобы не плодить аллокации).
func process(input: PackedFloat32Array, out: PackedFloat32Array) -> void:
	var n := input.size()
	if n == 0:
		return
	if not _primed:
		# Первый буфер: стартуем с нулевой позиции, _prev ещё не осмыслен — берём input[0].
		_prev = input[0]
		_primed = true
	# Генерируем семплы, пока для интерполяции есть правая опора (индекс i+1 в пределах буфера).
	while _pos < float(n - 1):
		var i := int(floor(_pos))
		var frac := _pos - float(i)
		var s0 := _prev if i < 0 else input[i]
		var s1 := input[i + 1]
		out.push_back(s0 + (s1 - s0) * frac)
		_pos += _step
	# Переносим хвост: следующий буфер начинается с индекса 0, поэтому сдвигаем позицию
	# на длину этого буфера, а его последний семпл становится «виртуальным -1».
	_prev = input[n - 1]
	_pos -= float(n)
